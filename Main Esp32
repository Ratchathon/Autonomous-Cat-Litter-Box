// =========================
// WIFI
// =========================
void connectWiFi(){

  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID,WIFI_PASS);

  lcd.clear();
  lcd.print("CONNECT WIFI...");

  Serial.print("Connecting");

  unsigned long start = millis();

  while(WiFi.status()!=WL_CONNECTED && millis()-start<20000){

    Serial.print(".");
    delay(500);
  }

  Serial.println();

  if(WiFi.status()==WL_CONNECTED){

    Serial.println("WiFi connected");
    Serial.println(WiFi.localIP());

    lcd.clear();
    lcd.print("WIFI OK");

    lcd.setCursor(0,1);
    lcd.print(WiFi.localIP().toString());

    delay(2000);

  }
  else{

    lcd.clear();
    lcd.print("WIFI FAILED");

    delay(2000);
  }
}

// =========================
// JSON command parser
// =========================
String extractCommand(String payload){

  int keyPos = payload.indexOf("\"command\":\"");

  if(keyPos<0) return "";

  int start = keyPos + 11;

  int end = payload.indexOf("\"",start);

  if(end<0) return "";

  return payload.substring(start,end);
}

// =========================
// HTTP GET
// =========================
String httpGetString(String url,int &httpCode){

  HTTPClient http;

  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  http.begin(url);

  httpCode = http.GET();

  String payload="";

  if(httpCode>0){
    payload = http.getString();
  }

  http.end();

  return payload;
}

// =========================
// POLL COMMAND
// =========================
void pollCommandFromServer(){

  if(WiFi.status()!=WL_CONNECTED) return;
  if(isCleaning) return;

  int httpCode = 0;

  String getUrl = String(APPS_SCRIPT_URL) + "?action=getCommand";

  String payload = httpGetString(getUrl,httpCode);

  if(httpCode != 200){
    Serial.println("Poll failed");
    return;
  }

  String cmd = extractCommand(payload);

  if(cmd == "") return;

  Serial.print("CMD: ");
  Serial.println(cmd);

  if(cmd == "start"){

    Serial.println("START COMMAND");

    int clearCode = 0;
    String clearUrl = String(APPS_SCRIPT_URL) + "?action=clearCommand";
    httpGetString(clearUrl,clearCode);

    lcd.clear();
    lcd.print("CMD: START");

    delay(500);

    startCleaning();
  }
}
// =========================
// SETUP
// =========================
void setup(){

  Serial.begin(115200);

  Wire.begin(21,22);

  lcd.init();
  lcd.backlight();

  lcd.print("SYSTEM STARTING");

  //-------------------------------------------------//
  pinMode(IN1,OUTPUT);
  pinMode(IN2,OUTPUT);
  pinMode(IN3,OUTPUT);
  pinMode(IN4,OUTPUT);

  pinMode(sensorEntry,INPUT_PULLUP);
  pinMode(sensorInside,INPUT_PULLUP);
  //-------------------------------------------------//
  servo1.attach(pinS1);
  servo2.attach(pinS2);

  servo1.write(90);
  servo2.write(90);
  //-------------------------------------------------//
  pinMode(sensorEntry, INPUT_PULLUP);
  pinMode(sensorInside, INPUT_PULLUP);

  attachInterrupt(digitalPinToInterrupt(sensorEntry), catInterrupt, FALLING);
  attachInterrupt(digitalPinToInterrupt(sensorInside), catInterrupt, FALLING);
  //-------------------------------------------------//
  stopDC();

  connectWiFi();

  server.on("/",HTTP_GET,handleRoot);
  server.on("/status",HTTP_GET,handleStatus);
  server.on("/start",HTTP_GET,handleStart);

  espClient.setInsecure(); // ใช้ TLS แบบง่าย (HiveMQ)
  client.setServer(mqtt_server, 8883); // ใช้ port TLS
  client.setCallback(callback);

  server.onNotFound(handleNotFound);

  server.begin();

  lcd.clear();
  lcd.print("READY (90 DEG)");
}

// =========================
// LOOP
// =========================
void loop(){

  server.handleClient();

  if (!client.connected()) {
  connectMQTT();
  }
  client.loop();


  if(webStartRequested && !isCleaning){

    webStartRequested=false;

    startCleaning();
  }

  if(millis()-lastPoll>=pollInterval){

    lastPoll=millis();

    pollCommandFromServer();
  }

  if(!isCleaning && digitalRead(sensorInside)==LOW){

    lcd.clear();
    lcd.print("CAT DETECTED");

    while(digitalRead(sensorInside)==LOW || digitalRead(sensorEntry)==LOW){

      server.handleClient();
      delay(200);
    }

    lcd.clear();
    lcd.print("CLEANING IN 3S");

    catSafetyDelay(3000);

    startCleaning();
  }
}
