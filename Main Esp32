void handleStatus() {

  sendCorsHeaders();

  String json = "{";

  json += "\"ok\":true,";
  json += "\"ip\":\"" + WiFi.localIP().toString() + "\",";
  json += "\"rssi\":" + String(WiFi.RSSI()) + ",";
  json += "\"cleaning\":" + String(isCleaning ? "true":"false") + ",";
  json += "\"sensorInside\":" + String(digitalRead(sensorInside)==LOW ? "true":"false") + ",";
  json += "\"sensorEntry\":" + String(digitalRead(sensorEntry)==LOW ? "true":"false");

  json += "}";

  server.send(200,"application/json",json);
}

// =========================
// START CLEAN
// =========================
void handleStart() {

  sendCorsHeaders();

  if(isCleaning){

    server.send(200,"application/json",
