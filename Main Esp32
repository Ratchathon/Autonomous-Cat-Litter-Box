// =========================
// STOP MOTOR
// =========================
void stopDC() {

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  analogWrite(IN1, 0);
  analogWrite(IN2, 0);
  analogWrite(IN3, 0);
  analogWrite(IN4, 0);
}

// =========================
// SAFETY SENSOR
// =========================
volatile bool catDetected = false;

void IRAM_ATTR catInterrupt() {
  catDetected = true;
}

bool isCatIn() {

  if (catDetected) {

    stopDC();

    lcd.setCursor(0,1);
    lcd.print("!!! PAUSED !!! ");

    return true;
  }

  return false;
}

// =========================
// delay with sensor check
// =========================
void catSafetyDelay(unsigned long ms) {

  unsigned long start = millis();

  while (millis() - start < ms) {

    server.handleClient();

    if (isCatIn()) {

      while (digitalRead(sensorEntry) == LOW || digitalRead(sensorInside) == LOW) {

        server.handleClient();
        delay(100);

      }

      lcd.setCursor(0,1);
      lcd.print("Resuming...    ");
      delay(1000);
      lcd.setCursor(0,1);
      lcd.print("                ");
    }

    delay(10);
  }
}

// =========================
// MOTOR CONTROL
// =========================
void runMotorSafe(unsigned long duration, bool forward) {

  unsigned long startT = millis();
  unsigned long elapsed = 0;

  while (elapsed < duration) {

    server.handleClient();

    if (isCatIn()) {

      while (digitalRead(sensorEntry) == LOW || digitalRead(sensorInside) == LOW) {
        server.handleClient();
        delay(100);
      }

      delay(1000);

      startT = millis() - elapsed;
    }

    if (forward) {

      analogWrite(IN1, motorSpeed);
      digitalWrite(IN2, LOW);

      analogWrite(IN3, motorSpeed);
      digitalWrite(IN4, LOW);

    }
    else {

      digitalWrite(IN1, LOW);
      analogWrite(IN2, motorSpeed);

      digitalWrite(IN3, LOW);
      analogWrite(IN4, motorSpeed);

    }

    elapsed = millis() - startT;
    delay(10);
  }

  stopDC();
}

int degToUs(int deg) {
  return map(constrain(deg,0,180), 0, 180, 500, 2400);
}
// =========================
// CLEANING
// =========================
void startCleaning() {

  isCleaning = true;

  lcd.clear();
  lcd.print("1: SERVO TO 160");

  servo1.writeMicroseconds(degToUs(160));
  servo2.writeMicroseconds(degToUs(160));

  catSafetyDelay(800);

  lcd.clear();
  lcd.print("2: MOVING FWD");

  runMotorSafe(1000, true);

  lcd.clear();
  lcd.print("3: RESET TO 90");

  servo1.writeMicroseconds(degToUs(90));
  servo2.writeMicroseconds(degToUs(90));

  catSafetyDelay(800);

  lcd.clear();
  lcd.print("4: MOVING BWD");

  runMotorSafe(1000, false);

  lcd.clear();
  lcd.print("5: SERVO TO 20");

  servo1.writeMicroseconds(degToUs(20));
  servo2.writeMicroseconds(degToUs(160));

  catSafetyDelay(800);

  lcd.clear();
  lcd.print("6: RESET TO 90");

  servo1.writeMicroseconds(degToUs(90));
  servo2.writeMicroseconds(degToUs(90));

  catSafetyDelay(800);

  lcd.clear();
  lcd.print("   COMPLETE   ");

  delay(2000);

  lcd.clear();
  lcd.print("READY (90 DEG)");

  isCleaning = false;
}
